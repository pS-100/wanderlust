<% layout('/layouts/boilerplate') -%>

    <style>
        /* .scroll-container {
                display: flex;
                flex-wrap: wrap;
                align-items: center;
            } */

        .filter {
            text-align: center;
            margin-right: 2rem;
            margin-top: 2rem;
            opacity: .7;
        }

        .filter:hover {
            cursor: pointer;
            opacity: 1;
        }

        .filter p {
            font-size: .6rem;
        }

        .tax-info {
            display: none;
        }

        .tax-toggle {
            border: 1px solid black;
            border-radius: 1rem;
            height: 3.2rem;
            padding: 1rem;
            margin-left: 2rem;
            display: flex;
            align-items: center;
        }

        .filters-wrapper {
            display: flex;
            align-items: center;
            gap: .8rem;
        }

        .scroll-container {
            display: flex;
            overflow-x: auto;
            flex: 1;
            gap: 1rem;
            scrollbar-width: none;
        }

        .scroll-container::-webkit-scrollbar {
            display: none;
        }

        .filter {
            flex-shrink: 0;
        }

        .tax-toggle {
            flex-shrink: 0;
            white-space: nowrap;
        }

        .scroll-container a {
            text-decoration: none;
            color: inherit;
        }

        .active {
            color: #fe424d;
            border-bottom: 2px solid #fe424d;
        }

        .activet {
            color: #fc520f;
            border-bottom: 2px solid #fc520f;
        }

        @media (max-width:768px) {

            .filters-wrapper {
                flex-direction: column;
                align-items: stretch;
            }

            .scroll-container {
                width: 100%;
            }

            .tax-toggle {
                width: 100%;
                margin: 0;
                justify-content: center;
            }
        }
    </style>
    <div class="filters-wrapper">

        <div class="scroll-container">

            <a href="/listings?category=trending">
                <div class="filter <%= selectedCategory===" trending" ? "activet" :"" %> ">
                    <div><i class="fa-solid fa-fire"></i></div>
                    <p>Trending</p>
                </div>
            </a>

            <a href="/listings?category=rooms">
                <div class="filter <%= selectedCategory===" rooms" ? "active" :"" %> ">
                    <div><i class="fa-solid fa-bed"></i></div>
                    <p>Rooms</p>
                </div>
            </a>

            <a href="/listings?category=iconic cities">
                <div class="filter <%= selectedCategory===" iconic cities" ? "active" :"" %> ">
                    <div><i class="fa-solid fa-monument"></i></div>
                    <p>Iconic Cities</p>
                </div>
            </a>

            <a href="/listings?category=mountains">
                <div class="filter <%= selectedCategory===" mountains" ? "active" :"" %> ">
                    <div><i class="fa-solid fa-mountain"></i></div>
                    <p>Mountains</p>
                </div>
            </a>

            <a href="/listings?category=amazing pools">
                <div class="filter <%= selectedCategory===" amazing pools" ? "active" :"" %> ">
                    <div><i class="fa-solid fa-person-swimming"></i></div>
                    <p>Amazing Pools</p>
                </div>
            </a>

            <a href="/listings?category=castles">
                <div class="filter <%= selectedCategory===" castles" ? "active" :"" %> ">
                    <div><i class="fa-brands fa-fort-awesome"></i></div>
                    <p>Castles</p>
                </div>
            </a>

            <a href="/listings?category=camping">
                <div class="filter <%= selectedCategory===" camping" ? "active" :"" %> ">
                    <div><i class="fa-solid fa-campground"></i></div>
                    <p>Camping</p>
                </div>
            </a>

            <a href="/listings?category=farms">
                <div class="filter <%= selectedCategory===" farms" ? "active" :"" %> ">
                    <div><i class="fa-solid fa-cow"></i></div>
                    <p>Farms</p>
                </div>
            </a>

            <a href="/listings?category=arctic">
                <div class="filter <%= selectedCategory===" arctic" ? "active" :"" %> ">
                    <div><i class="fa-regular fa-snowflake"></i></div>
                    <p>Arctic</p>
                </div>
            </a>

            <a href="/listings?category=domes">
                <div class="filter <%= selectedCategory===" domes" ? "active" :"" %> ">
                    <div><i class="fa-solid fa-igloo"></i></div>
                    <p>Domes</p>
                </div>
            </a>

            <a href="/listings?category=boats">
                <div class="filter <%= selectedCategory===" boats" ? "active" :"" %> ">
                    <div><i class="fa-solid fa-sailboat"></i></div>
                    <p>Boats</p>
                </div>
            </a>

        </div>
        <div class="tax-toggle">
            <div class="form-check-reverse form-switch">
                <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
                <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
            </div>
        </div>
    </div>

    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
        <%for(let listing of allListings) {%>
            <a href="/listings/<%= listing._id%>" class="listing-link">
                <div class="card col listing-card">
                    <img src="<%=listing.image.url%>" class="card-img-top " alt="listing_image" style="height: 20rem">
                    <div class="card-img-overlay"></div>
                    <div class="card-body">
                        <p class="card-text">
                            <b>
                                <%=listing.title%>
                            </b>
                            <br>
                            &#8377;<%=listing.price.toLocaleString("eng-IN")%> / night
                                <i class="tax-info">&nbsp;&nbsp;+18% GST</i>
                        </p>
                    </div>
                </div>
            </a>
            <%}%>
    </div>
    <script>
        let taxSwitch = document.getElementById("switchCheckDefault");
        taxSwitch.addEventListener("click", () => {
            let taxInfo = document.getElementsByClassName("tax-info");
            for (info of taxInfo) {
                if (info.style.display != "inline") {
                    info.style.display = "inline";
                } else {
                    info.style.display = "none";
                }
            }
        })

    </script>